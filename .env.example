# Judge Arena - LLM-as-a-Judge Data Labelling Studio
# Copy this file to .env.local and fill in your values

# ─── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
# If password contains special characters (e.g. @, :, /), URL-encode them.
DATABASE_URL="postgresql://judge_arena:password@localhost:5432/judge_arena"

# ─── Authentication ─────────────────────────────────────────────────────────────
# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Encryption ─────────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting API keys at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── LLM Provider API Keys ─────────────────────────────────────────────────────
# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=

# Local Model Endpoint (e.g., Ollama, vLLM, llama.cpp)
# LOCAL_MODEL_ENDPOINT=http://localhost:11434/v1

# ─── Redis (optional — required for SSE realtime adapter) ───────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Realtime / SSE ────────────────────────────────────────────────────────────
# Adapter for server-sent events: "memory" (default) or "redis"
# REALTIME_ADAPTER=memory

# ─── Evaluation Engine ─────────────────────────────────────────────────────────
# EVALUATION_RUN_QUEUE_CONCURRENCY=4
# EVALUATION_MODEL_CONCURRENCY_PER_RUN=2
# EVALUATION_MODEL_TIMEOUT_MS=120000

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# Override default rate limits (requests per window)
# RATE_LIMIT_AUTH=5          # Auth endpoints per minute
# RATE_LIMIT_API=60          # General API per minute
# RATE_LIMIT_JUDGE=10        # Evaluation runs per minute

# ─── Logging ────────────────────────────────────────────────────────────────────
# LOG_LEVEL=info             # debug | info | warn | error | fatal

# ─── Proxy / Deployment ────────────────────────────────────────────────────────
# Set to "true" when behind a reverse proxy (Railway, Vercel, etc.)
# Required for correct client IP detection in rate limiting.
# TRUSTED_PROXY=true

# Railway injects this automatically — used in CSP connect-src
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

# ─── Seed Data ─────────────────────────────────────────────────────────────────
# Override default seed passwords for production deployments
# SEED_ADMIN_PASSWORD=changeme
# SEED_DEMO_PASSWORD=changeme

# ─── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Judge Arena"
NODE_ENV=development
