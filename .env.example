# Judge Arena - LLM-as-a-Judge Data Labelling Studio
# Copy this file to .env.local and fill in your API keys

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=

# Local Model Endpoint (e.g., Ollama, vLLM, llama.cpp)
# LOCAL_MODEL_ENDPOINT=http://localhost:11434/v1

# Database URL (SQLite - default location)
DATABASE_URL="file:./dev.db"

# NextAuth (required for authentication)
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Application
NEXT_PUBLIC_APP_NAME="Judge Arena"
