generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  passwordHash   String
  role           String          @default("user") // "user" | "admin"
  projects       Project[]
  rubrics        Rubric[]
  modelConfigs   ModelConfig[]
  evaluations    Evaluation[]
  humanJudgments HumanJudgment[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

// ─── Domain ─────────────────────────────────────────────────────────────────

model Project {
  id          String       @id @default(cuid())
  name        String
  description String?
  rubricId    String?
  rubric      Rubric?      @relation(fields: [rubricId], references: [id])
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluations Evaluation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([rubricId])
  @@index([userId])
}

model Rubric {
  id          String            @id @default(cuid())
  name        String
  description String?
  version     Int               @default(1)
  parentId    String?           // null for v1; root rubric id for later versions
  parent      Rubric?           @relation("RubricVersions", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  versions    Rubric[]          @relation("RubricVersions")
  criteria    RubricCriterion[]
  projects    Project[]
  evaluations Evaluation[]
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([parentId])
  @@index([userId])
}

model RubricCriterion {
  id          String @id @default(cuid())
  rubricId    String
  rubric      Rubric @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  name        String
  description String
  maxScore    Int    @default(10)
  weight      Float  @default(1.0)
  order       Int    @default(0)

  @@index([rubricId])
}

model ModelConfig {
  id                 String                     @id @default(cuid())
  name               String
  provider           String // 'anthropic' | 'openai' | 'local'
  modelId            String // e.g. 'claude-sonnet-4-5-20250514'
  endpoint           String? // custom endpoint for local/self-hosted models
  apiKey             String? // stored per-model (optional, falls back to env)
  isActive           Boolean                    @default(true)
  isVerified         Boolean                    @default(false)
  verifiedAt         DateTime?
  verificationError  String?
  userId             String
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  judgments          ModelJudgment[]
  evaluationSelections EvaluationModelSelection[]

  @@index([userId])
}

model Evaluation {
  id             String          @id @default(cuid())
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rubricId       String?         // specific rubric version used (overrides project.rubricId)
  rubric         Rubric?         @relation(fields: [rubricId], references: [id])
  inputText      String
  title          String?
  status         String          @default("pending") // pending | judging | completed | error
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  modelJudgments ModelJudgment[]
  modelSelections EvaluationModelSelection[]
  humanJudgment  HumanJudgment?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([projectId])
  @@index([rubricId])
  @@index([status])
  @@index([userId])
}

model EvaluationModelSelection {
  id           String      @id @default(cuid())
  evaluationId String
  evaluation   Evaluation  @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  modelConfigId String
  modelConfig  ModelConfig @relation(fields: [modelConfigId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())

  @@unique([evaluationId, modelConfigId])
  @@index([evaluationId])
  @@index([modelConfigId])
}

model ModelJudgment {
  id            String      @id @default(cuid())
  evaluationId  String
  evaluation    Evaluation  @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  modelConfigId String
  modelConfig   ModelConfig @relation(fields: [modelConfigId], references: [id], onDelete: Cascade)
  overallScore  Float?
  reasoning     String?
  rawResponse   String?
  criteriaScores String? // JSON string: Array<{ criterionId: string; score: number; comment?: string }>
  latencyMs     Int?
  tokenCount    Int?
  status        String      @default("pending") // pending | running | completed | error
  error         String?
  createdAt     DateTime    @default(now())

  @@index([evaluationId])
  @@index([modelConfigId])
}

model HumanJudgment {
  id             String     @id @default(cuid())
  evaluationId   String     @unique
  evaluation     Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  overallScore   Float
  reasoning      String?
  criteriaScores String? // JSON string: Array<{ criterionId: string; score: number; comment?: string }>
  selectedBestModelId String?
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([userId])
}

model ApiKeyStore {
  id        String   @id @default(cuid())
  provider  String   @unique // 'anthropic' | 'openai'
  apiKey    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
